<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DnD_Index_App.Resources.Styles.ElementStyles">
    <Style TargetType="Label" Class="H1">
        <Setter Property="TextColor" Value="{DynamicResource CurrentTitleColour}" />
        <Setter Property="FontSize" Value="42"/>
        <Setter Property="FontAttributes" Value="Bold"/>
    </Style>
    <Style TargetType="Label" Class="H2">
        <Setter Property="TextColor" Value="{DynamicResource CurrentH2Colour}" />
        <Setter Property="FontSize" Value="26"/>
        <Setter Property="FontAttributes" Value="Bold"/>
    </Style>
    <Style TargetType="Label" Class="H3">
        <Setter Property="TextColor" Value="{DynamicResource CurrentH3Colour}" />
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontAttributes" Value="Bold"/>
    </Style>
    <Style TargetType="Label" Class="SubtitleText">
        <Setter Property="TextColor" Value="{DynamicResource CurrentTextColour}"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontAttributes" Value="Italic"/>
    </Style>
    <Style TargetType="Label" Class="SectionBold">
        <Setter Property="TextColor" Value="{DynamicResource CurrentTextColour}" />
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontAttributes" Value="Bold"/>
    </Style>
    <Style TargetType="Label" Class="SectionText">
        <Setter Property="TextColor" Value="{DynamicResource CurrentTextColour}" />
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontAttributes" Value="None"/>
    </Style>
    <Style TargetType="Image" Class="HeaderIcon">
        <Setter Property="HeightRequest" Value="28"/>
        <Setter Property="WidthRequest" Value="28"/>
    </Style>
</ResourceDictionary>